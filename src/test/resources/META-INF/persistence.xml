<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="agilexpert-test-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <class>hu.agilexpert.model.App</class>
        <class>hu.agilexpert.model.BackgroundImage</class>
        <class>hu.agilexpert.model.Icon</class>
        <class>hu.agilexpert.model.Menu</class>
        <class>hu.agilexpert.model.MenuItem</class>
        <class>hu.agilexpert.model.Theme</class>
        <class>hu.agilexpert.model.UserAccount</class>
        
        <properties>
            <!-- In-memory H2 DB for testing -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1" />
            <property name="jakarta.persistence.jdbc.user" value="sa" />
            <property name="jakarta.persistence.jdbc.password" value="" />
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver" />

            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect" />
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create" />
            <property name="hibernate.show_sql" value="true" />
        </properties>
    </persistence-unit>
</persistence>
